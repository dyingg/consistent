# Database
# Note: the DB role must have CREATE privilege on either the 'public' or the
# 'mastra' schema. Mastra creates and owns the 'mastra' schema for agent
# thread memory (threads, messages, resources) at boot. Drizzle migrations
# continue to own 'public'.
DATABASE_URL=postgresql://consistent:consistent@localhost:5432/consistent

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3001

# Web origin (for CORS + trusted origins)
WEB_ORIGIN=http://localhost:3000

# Next.js public env vars (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001

# AI Agent
# OPENAI_API_KEY is required at boot when AI_MODEL starts with 'openai/';
# ANTHROPIC_API_KEY is required when AI_MODEL starts with 'anthropic/'.
AI_MODEL=openai/gpt-5.2
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
