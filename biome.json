{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": false
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      ".next",
      "drizzle",
      "*.config.ts",
      "*.config.mjs"
    ]
  }
}
